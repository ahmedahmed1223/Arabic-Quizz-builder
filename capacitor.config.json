{
  "appId": "com.ahmedahmed1223.arabicquizzbuilder",
  "appName": "منصة المسابقات التفاعلية",
  "webDir": "dist",
  "backgroundColor": "#08091a",
  "loggingBehavior": "production",
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "launchAutoHide": true,
      "backgroundColor": "#08091a",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#08091a",
      "overlaysWebView": false
    },
    "Haptics": {
      "enabled": true
    },
    "App": {
      "logsEnabled": false
    }
  },
  "server": {
    "androidScheme": "https",
    "cleartext": true
  }
}
