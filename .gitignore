# ═════════════════════════════════════════════════════════════════
# .gitignore — Quiz Platform
# ═════════════════════════════════════════════════════════════════

# ── Node.js ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.pnpm-store/

# ── Build output ──
# Note: dist/ is intentionally NOT ignored — the built single-file HTML
# is included in the repo so users can download/use it directly without
# having to run a build. The build output is the distributable artifact.
# dist/
build/
.output/
.vite/

# ── Temporary files ──
.extracted/
.tmp/
*.tmp
*.log
.cache/

# ── OS files ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── IDE / Editor ──
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ── Environment ──
.env
.env.local
.env.*.local

# ── Test coverage ──
coverage/
.nyc_output/

# ── Misc ──
*.bak
*.orig
